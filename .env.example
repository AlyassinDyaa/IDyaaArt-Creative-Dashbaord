# IDyaaArt environment variables.
# On Vercel: set these in Project → Settings → Environment Variables.
# Locally: the server doesn't auto-load .env — either export these in your shell,
# or put the r2 block into .entropy/config.json (see below).

# --- MongoDB (documents + folder tree + account) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=entropy

# --- Claude (cloud only; subscription token or API key) ---
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudflare R2 (image/PDF blob storage) ---
# Create a bucket in Cloudflare → R2, enable Public access (or a custom domain),
# then make an R2 API token (Object Read & Write) for the keys below.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=idyaa-files
# The bucket's public base URL (the pub-xxxx.r2.dev domain, or your custom domain).
# Required for images to load in the browser.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Local alternative to the R2_* vars above — add to .entropy/config.json:
# {
#   "r2": {
#     "accountId": "...", "accessKeyId": "...", "secretAccessKey": "...",
#     "bucket": "idyaa-files", "publicUrl": "https://pub-xxxx.r2.dev"
#   }
# }
